# ═══════════════════════════════════════════════════════
#   AI SMART MIRROR — Environment Variables
#   Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════

# ─── Database (PostgreSQL) ────────────────────────────
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_PORT=5432

# ─── Application ─────────────────────────────────────
SECRET_KEY=generate-a-strong-random-key-here
DEBUG=false

# ─── Cloud Storage (Cloudflare R2 / AWS S3) ──────────
STORAGE_PROVIDER=local
# STORAGE_PROVIDER=r2
# STORAGE_BUCKET=smart-mirror
# STORAGE_ACCESS_KEY=your_access_key
# STORAGE_SECRET_KEY=your_secret_key
# STORAGE_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
# STORAGE_PUBLIC_URL=https://pub-xxxx.r2.dev

# ─── GPU Server (RunPod) ─────────────────────────────
GPU_SERVER_URL=http://localhost:8001
GPU_SERVER_API_KEY=your_gpu_api_key

# ─── AI Provider ─────────────────────────────────────
AI_PROVIDER=mock
# AI_PROVIDER=replicate
# REPLICATE_API_TOKEN=your_replicate_token
